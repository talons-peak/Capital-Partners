{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm --filter @workspace/pe-website run build",
  "installCommand": "pnpm install --frozen-lockfile",
  "outputDirectory": "artifacts/pe-website/dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/((?!assets/).*)", "destination": "/index.html" }
  ]
}
